{
  "version": "v3",
  "pipeline_id": "deduplication-demo-pipeline",
  "sources": [
    {
      "type": "kafka",
      "source_id": "users",
      "connection_params": {
        "brokers": ["kafka:9093"],
        "protocol": "PLAINTEXT",
        "mechanism": "NO_AUTH"
      },
      "topic": "users",
      "consumer_group_initial_offset": "latest",
      "schema_fields": [
        {"name": "event_id", "type": "string"},
        {"name": "user.id", "type": "string"},
        {"name": "user.name", "type": "string"},
        {"name": "user.email", "type": "string"},
        {"name": "created_at", "type": "string"},
        {"name": "tags", "type": "array"}
      ]
    }
  ],
  "transforms": [
    {
      "type": "dedup",
      "source_id": "users",
      "config": {
        "key": "event_id",
        "time_window": "1h"
      }
    }
  ],
  "sink": {
    "type": "clickhouse",
    "connection_params": {
      "host": "clickhouse",
      "port": "9000",
      "http_port": "8123",
      "database": "default",
      "username": "default",
      "password": "secret",
      "secure": false
    },
    "table": "users_dedup",
    "max_batch_size": 1000,
    "max_delay_time": "10s",
    "mapping": [
      {"name": "event_id", "column_name": "event_id", "column_type": "UUID"},
      {"name": "user.id", "column_name": "user_id", "column_type": "UUID"},
      {"name": "created_at", "column_name": "created_at", "column_type": "DateTime"},
      {"name": "user.name", "column_name": "name", "column_type": "String"},
      {"name": "user.email", "column_name": "email", "column_type": "String"},
      {"name": "tags", "column_name": "tags", "column_type": "Array(String)"}
    ]
  }
}
