{
  "version": "v3",
  "pipeline_id": "fraud-detection-logins-tested",
  "name": "Fraud Detection Logins Tested",
  "sources": [
    {
      "type": "kafka",
      "source_id": "login-attempts",
      "connection_params": {
        "brokers": ["kafka.kafka.svc.cluster.local:9092"],
        "protocol": "SASL_PLAINTEXT",
        "mechanism": "PLAIN",
        "username": "${KAFKA_USERNAME}",
        "password": "${KAFKA_PASSWORD}"
      },
      "topic": "login-attempts",
      "consumer_group_initial_offset": "earliest",
      "schema_fields": [
        {"name": "event_id", "type": "string"},
        {"name": "event_time", "type": "string"},
        {"name": "user_id", "type": "string"},
        {"name": "ip_address", "type": "string"},
        {"name": "device_id", "type": "string"},
        {"name": "country", "type": "string"},
        {"name": "status", "type": "string"},
        {"name": "failure_reason", "type": "string"}
      ]
    }
  ],
  "transforms": [
    {
      "type": "filter",
      "source_id": "login-attempts",
      "config": {
        "expression": "status != 'failed'"
      }
    },
    {
      "type": "dedup",
      "source_id": "login-attempts",
      "config": {
        "key": "event_id",
        "time_window": "1h"
      }
    }
  ],
  "sink": {
    "type": "clickhouse",
    "connection_params": {
      "host": "clickhouse.clickhouse.svc.cluster.local",
      "port": "9000",
      "http_port": "8123",
      "database": "default",
      "username": "${CLICKHOUSE_USER}",
      "password": "${CLICKHOUSE_PASSWORD}",
      "secure": false
    },
    "table": "fraud_login_events",
    "max_batch_size": 500,
    "max_delay_time": "10s",
    "mapping": [
      {"name": "event_id", "column_name": "event_id", "column_type": "UUID"},
      {"name": "event_time", "column_name": "event_time", "column_type": "DateTime"},
      {"name": "user_id", "column_name": "user_id", "column_type": "String"},
      {"name": "ip_address", "column_name": "ip_address", "column_type": "String"},
      {"name": "device_id", "column_name": "device_id", "column_type": "String"},
      {"name": "country", "column_name": "country", "column_type": "String"},
      {"name": "status", "column_name": "status", "column_type": "LowCardinality(String)"},
      {"name": "failure_reason", "column_name": "failure_reason", "column_type": "LowCardinality(String)"}
    ]
  },
  "metadata": {
    "tags": ["tutorial", "fraud-detection"]
  }
}
