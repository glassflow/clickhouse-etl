          "rawSql": "SELECT\n  count() AS breached_cells\nFROM (\n  SELECT\n    CellID,\n    avg(Value) AS avg_rsrp\n  FROM ran_metrics\n  WHERE MetricName = 'ran.rsrp'\n    AND $__timeFilter(TimeUnix)\n  GROUP BY CellID\n  HAVING avg_rsrp < -110\n)",
