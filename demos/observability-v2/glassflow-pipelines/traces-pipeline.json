{
  "version": "v3",
  "pipeline_id": "otlp-traces",
  "name": "OTLP Traces Pipeline",
  "sources": [
    {
      "type": "otlp.traces",
      "source_id": "traces"
    }
  ],
  "transforms": [
    {
      "type": "dedup",
      "source_id": "traces",
      "config": {
        "key": "span_id",
        "time_window": "1h"
      }
    },
    {
      "type": "stateless",
      "source_id": "traces",
      "config": {
        "transforms": [
          {
            "expression": "start_timestamp",
            "output_name": "start_timestamp",
            "output_type": "string"
          },
          {
            "expression": "trace_id",
            "output_name": "trace_id",
            "output_type": "string"
          },
          {
            "expression": "span_id",
            "output_name": "span_id",
            "output_type": "string"
          },
          {
            "expression": "parent_span_id",
            "output_name": "parent_span_id",
            "output_type": "string"
          },
          {
            "expression": "trace_state",
            "output_name": "trace_state",
            "output_type": "string"
          },
          {
            "expression": "name",
            "output_name": "name",
            "output_type": "string"
          },
          {
            "expression": "kind",
            "output_name": "kind",
            "output_type": "string"
          },
          {
            "expression": "{'service.name': resource_attributes['service.name'], 'user_email': '[REDACTED]', 'demo_ssn': '[REDACTED]'}",
            "output_name": "resource_attributes",
            "output_type": "map"
          },
          {
            "expression": "scope_name",
            "output_name": "scope_name",
            "output_type": "string"
          },
          {
            "expression": "scope_version",
            "output_name": "scope_version",
            "output_type": "string"
          },
          {
            "expression": "{'user_email': '[REDACTED]', 'demo_ssn': '[REDACTED]'}",
            "output_name": "attributes",
            "output_type": "map"
          },
          {
            "expression": "duration_ns",
            "output_name": "duration_ns",
            "output_type": "uint"
          },
          {
            "expression": "status_code",
            "output_name": "status_code",
            "output_type": "string"
          },
          {
            "expression": "status_message",
            "output_name": "status_message",
            "output_type": "string"
          }
        ]
      }
    }
  ],
  "sink": {
    "type": "clickhouse",
    "connection_params": {
      "host": "hyperdx-clickstack-clickhouse.hyperdx.svc.cluster.local",
      "port": "9000",
      "http_port": "8123",
      "database": "default",
      "username": "otelcollector",
      "password": "otelcollectorpass",
      "secure": false,
      "skip_certificate_verification": true
    },
    "table": "otel_traces",
    "max_batch_size": 1000,
    "max_delay_time": "1s",
    "mapping": [
      {
        "name": "start_timestamp",
        "column_name": "Timestamp",
        "column_type": "DateTime64(9)"
      },
      {
        "name": "trace_id",
        "column_name": "TraceId",
        "column_type": "String"
      },
      {
        "name": "span_id",
        "column_name": "SpanId",
        "column_type": "String"
      },
      {
        "name": "parent_span_id",
        "column_name": "ParentSpanId",
        "column_type": "String"
      },
      {
        "name": "trace_state",
        "column_name": "TraceState",
        "column_type": "String"
      },
      {
        "name": "name",
        "column_name": "SpanName",
        "column_type": "LowCardinality(String)"
      },
      {
        "name": "kind",
        "column_name": "SpanKind",
        "column_type": "LowCardinality(String)"
      },
      {
        "name": "resource_attributes",
        "column_name": "ResourceAttributes",
        "column_type": "Map(String, String)"
      },
      {
        "name": "scope_name",
        "column_name": "ScopeName",
        "column_type": "String"
      },
      {
        "name": "scope_version",
        "column_name": "ScopeVersion",
        "column_type": "String"
      },
      {
        "name": "attributes",
        "column_name": "SpanAttributes",
        "column_type": "Map(String, String)"
      },
      {
        "name": "duration_ns",
        "column_name": "Duration",
        "column_type": "UInt64"
      },
      {
        "name": "status_code",
        "column_name": "StatusCode",
        "column_type": "LowCardinality(String)"
      },
      {
        "name": "status_message",
        "column_name": "StatusMessage",
        "column_type": "String"
      }
    ]
  },
  "resources": {
    "transform": [
      {
        "source_id": "traces",
        "replicas": 1,
        "storage": {
          "size": "5Gi"
        },
        "requests": {
          "cpu": "250m",
          "memory": "256Mi"
        },
        "limits": {
          "cpu": "500m",
          "memory": "512Mi"
        }
      }
    ],
    "sink": {
      "replicas": 1,
      "requests": {
        "cpu": "250m",
        "memory": "256Mi"
      },
      "limits": {
        "cpu": "500m",
        "memory": "512Mi"
      }
    }
  },
  "metadata": {
    "tags": [
      "observability",
      "otlp"
    ]
  }
}
