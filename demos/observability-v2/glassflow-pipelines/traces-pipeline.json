{
    "pipeline_id": "otlp-traces",
    "name": "OTLP Traces Pipeline",
    "version": "v3",
    "pipeline_resources": {
        "ingestor": {
            "base": {
                "replicas": 1,
                "requests": {"cpu": "1500m", "memory": "512Mi"},
                "limits": {"cpu": "1500m", "memory": "1024Mi"}
            }
        },
        "sink": {
            "replicas": 1,
            "requests": { "cpu": "1500m", "memory": "2Gi" },
            "limits":   { "cpu": "1500m", "memory": "2Gi" }
        }
    },
    "source": {
        "type": "otlp.traces",
        "id": "otlp-traces",
        "deduplication": {
            "enabled": true,
            "key": "trace_id",
            "time_window": "10m0s"
        }
    },
    "sink": {
        "type": "clickhouse",
        "connection_params": {
            "host": "hyperdx-clickstack-clickhouse.hyperdx.svc.cluster.local",
            "port": "9000",
            "http_port": "8123",
            "database": "default",
            "username": "otel",
            "password": "password",
            "secure": false,
            "skip_certificate_verification": true
        },
        "table": "otel_traces",
        "max_batch_size": 30000,
        "max_delay_time": "5s",
        "source_id": "otlp-traces",
        "mapping": [
            {"name":  "trace_id", "column_name": "trace_id", "column_type":  "String"},
            {"name":  "span_id", "column_name": "span_id", "column_type":  "String"},
            {"name":  "parent_span_id", "column_name": "parent_span_id", "column_type":  "String"},
            {"name":  "trace_state", "column_name": "trace_state", "column_type":  "String"},
            {"name":  "flags", "column_name": "flags", "column_type":  "UInt32"},
            {"name":  "name", "column_name": "name", "column_type":  "LowCardinality(String)"},
            {"name":  "kind", "column_name": "kind", "column_type":  "LowCardinality(String)"},
            {"name":  "start_timestamp", "column_name": "start_timestamp", "column_type":  "DateTime64(9)"},
            {"name":  "end_timestamp", "column_name": "end_timestamp", "column_type":  "DateTime64(9)"},
            {"name":  "duration_ns", "column_name": "duration_ns", "column_type":  "UInt64"},
            {"name":  "status_code", "column_name": "status_code", "column_type":  "LowCardinality(String)"},
            {"name":  "status_message", "column_name": "status_message", "column_type":  "String"},
            {"name":  "dropped_attributes_count", "column_name": "dropped_attributes_count", "column_type":  "Int32"},
            {"name":  "dropped_events_count", "column_name": "dropped_events_count", "column_type":  "Int32"},
            {"name":  "dropped_links_count", "column_name": "dropped_links_count", "column_type":  "Int32"},
            {"name":  "events", "column_name": "events", "column_type":  "Array(JSON)"},
            {"name":  "links", "column_name": "links", "column_type":  "Array(JSON)"},
            {"name":  "resource_attributes", "column_name": "resource_attributes", "column_type":  "Map(LowCardinality(String), String)"},
            {"name":  "scope_name", "column_name": "scope_name", "column_type":  "LowCardinality(String)"},
            {"name":  "scope_version", "column_name": "scope_version", "column_type":  "String"},
            {"name":  "scope_attributes", "column_name": "scope_attributes", "column_type":  "Map(LowCardinality(String), String)"},
            {"name":  "attributes", "column_name": "attributes", "column_type":  "Map(LowCardinality(String), String)"}
        ]
    },
    "metadata": {
        "tags": []
    }
}
